# Main
# Parse --version flag from all args
parse_version "$@"

case ${1:-help} in
    setup)
        cmd_setup
        ;;
    status)
        cmd_status
        ;;
    start)
        cmd_start ${2:-all}
        ;;
    stop)
        cmd_stop ${2:-all}
        ;;
    restart)
        cmd_stop ${2:-all}
        sleep 2
        cmd_start ${2:-all}
        ;;
    logs)
        cmd_logs $2
        ;;
    test)
        cmd_test
        ;;
    producer)
        cmd_producer
        ;;
    consumer)
        cmd_consumer
        ;;
    testdata)
        cmd_testdata "${@:2}"
        ;;
    lance)
        cmd_lance "${@:2}"
        ;;
    help|*)
        cmd_help
        ;;
esac
