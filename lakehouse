#!/bin/bash

set -e

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$PROJECT_ROOT"

# Load environment variables from .env if it exists
if [ -f "$PROJECT_ROOT/.env" ]; then
    set -a
    source "$PROJECT_ROOT/.env"
    set +a
fi

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Check if a command exists
check_cmd() {
    command -v "$1" >/dev/null 2>&1
}

# Check prerequisites and return missing ones
check_prerequisites() {
    local missing=()
    local warnings=()

    # Required commands
    check_cmd docker || missing+=("docker")
    check_cmd poetry || missing+=("poetry")
    check_cmd curl || missing+=("curl")

    # Check docker compose (v2 plugin)
    if check_cmd docker; then
        docker compose version >/dev/null 2>&1 || missing+=("docker-compose-plugin")
    fi

    # Optional but recommended
    check_cmd nc || warnings+=("nc (netcat) - needed for port checks")
    check_cmd psql || warnings+=("psql - needed for PostgreSQL tests")

    # Check Java version for Spark
    if check_cmd java; then
        local java_version=$(java -version 2>&1 | head -1 | cut -d'"' -f2 | cut -d'.' -f1)
        if [ "$java_version" -lt 17 ] 2>/dev/null; then
            warnings+=("Java 17+ recommended (found Java $java_version)")
        fi
    else
        warnings+=("java - needed for local spark-submit")
    fi

    # Check Python version
    if check_cmd python3; then
        local py_version=$(python3 -c 'import sys; print(sys.version_info.minor)')
        if [ "$py_version" -lt 10 ] 2>/dev/null; then
            warnings+=("Python 3.10+ recommended")
        fi
    fi

    # Report results
    if [ ${#missing[@]} -gt 0 ]; then
        echo -e "${RED}Missing required tools:${NC}"
        for tool in "${missing[@]}"; do
            echo -e "  ${RED}✗${NC} $tool"
        done
        return 1
    fi

    if [ ${#warnings[@]} -gt 0 ]; then
        echo -e "${YELLOW}Warnings:${NC}"
        for warn in "${warnings[@]}"; do
            echo -e "  ${YELLOW}!${NC} $warn"
        done
    fi

    return 0
}

# Default Spark version
SPARK_VERSION="4.1"

# Version-aware helpers
get_spark_compose() {
    case $SPARK_VERSION in
        4.0) echo "docker-compose.yml" ;;
        4.1) echo "docker-compose-spark41.yml" ;;
        *) echo "docker-compose-spark41.yml" ;;
    esac
}

get_spark_master_container() {
    case $SPARK_VERSION in
        4.0) echo "spark-master" ;;
        4.1) echo "spark-master-41" ;;
        *) echo "spark-master-41" ;;
    esac
}

get_spark_worker_container() {
    case $SPARK_VERSION in
        4.0) echo "spark-worker" ;;
        4.1) echo "spark-worker-41" ;;
        *) echo "spark-worker-41" ;;
    esac
}

get_spark_port() {
    case $SPARK_VERSION in
        4.0) echo "7077" ;;
        4.1) echo "7078" ;;
        *) echo "7078" ;;
    esac
}

get_spark_ui_port() {
    case $SPARK_VERSION in
        4.0) echo "8080" ;;
        4.1) echo "8082" ;;
        *) echo "8082" ;;
    esac
}

# Parse --version flag from args
parse_version() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            --version)
                SPARK_VERSION="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done
}

# Header
header() {
    echo -e "${BLUE}================================${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}================================${NC}"
}

# Check service status
check_service() {
    local service=$1
    local port=$2
    local name=$3
    
    if nc -z localhost $port 2>/dev/null; then
        echo -e "${GREEN}✓${NC} $name (port $port)"
        return 0
    else
        echo -e "${RED}✗${NC} $name (port $port)"
        return 1
    fi
}

# Check container
check_container() {
    local container=$1
    if docker ps --format '{{.Names}}' | grep -q "^${container}$"; then
        echo -e "${GREEN}✓${NC} $container"
        return 0
    else
        echo -e "${RED}✗${NC} $container"
        return 1
    fi
}

# Status command
cmd_status() {
    header "LAKEHOUSE STATUS"

    echo -e "\n${YELLOW}System Services:${NC}"
    check_service postgres 5432 "PostgreSQL"
    check_service seaweedfs 8333 "SeaweedFS"

    echo -e "\n${YELLOW}Spark 4.0 Containers:${NC}"
    check_container "spark-master" && docker exec spark-master /opt/spark/bin/spark-submit --version 2>&1 | grep "version" | head -1 || true
    check_container "spark-worker"

    echo -e "\n${YELLOW}Spark 4.1 Containers:${NC}"
    check_container "spark-master-41" && docker exec spark-master-41 /opt/spark/bin/spark-submit --version 2>&1 | grep "version" | head -1 || true
    check_container "spark-worker-41"

    echo -e "\n${YELLOW}Kafka Containers:${NC}"
    check_container "kafka"
    check_container "zookeeper"

    echo -e "\n${YELLOW}Ports:${NC}"
    echo "  PostgreSQL:       5432"
    echo "  SeaweedFS:        8333"
    echo "  Spark 4.0:        7077, 8080 (UI), 8081 (Worker UI)"
    echo "  Spark 4.1:        7078, 8082 (UI), 8083 (Worker UI)"
    echo "  Kafka:            9092"
    echo "  Zookeeper:        2181"

    echo -e "\n${YELLOW}Configurations:${NC}"
    echo "  Spark 4.0:   docker-compose.yml"
    echo "  Spark 4.1:   docker-compose-spark41.yml"
    echo "  Kafka:       docker-compose-kafka.yml"
    echo "  Spark conf:  config/spark/spark-defaults.conf"
}

# Start command
cmd_start() {
    header "STARTING SERVICES"

    local service=$1
    local compose_file=$(get_spark_compose)
    local spark_port=$(get_spark_port)

    case $service in
        spark|all)
            echo -e "${YELLOW}Starting Spark $SPARK_VERSION (port $spark_port)...${NC}"
            docker compose -f "$compose_file" up -d
            ;;
    esac

    case $service in
        kafka|all)
            echo -e "${YELLOW}Starting Kafka...${NC}"
            docker compose -f docker-compose-kafka.yml up -d
            ;;
    esac

    case $service in
        spark|kafka|all)
            ;;
        *)
            echo "Usage: lakehouse start [spark|kafka|all] [--version 4.0|4.1]"
            exit 1
            ;;
    esac

    if [ "$service" = "all" ]; then
        echo -e "\n${YELLOW}Waiting for services to be ready...${NC}"
        sleep 10
        cmd_status
    fi
}

# Stop command
cmd_stop() {
    header "STOPPING SERVICES"

    local service=$1
    local compose_file=$(get_spark_compose)

    case $service in
        spark|all)
            echo -e "${YELLOW}Stopping Spark $SPARK_VERSION...${NC}"
            docker compose -f "$compose_file" down
            ;;
    esac

    case $service in
        kafka|all)
            echo -e "${YELLOW}Stopping Kafka...${NC}"
            docker compose -f docker-compose-kafka.yml down
            ;;
    esac

    case $service in
        spark|kafka|all)
            ;;
        *)
            echo "Usage: lakehouse stop [spark|kafka|all] [--version 4.0|4.1]"
            exit 1
            ;;
    esac
}

# Logs command
cmd_logs() {
    local service=$1
    local master_container=$(get_spark_master_container)
    local worker_container=$(get_spark_worker_container)

    case $service in
        spark-master)
            echo -e "${YELLOW}Logs for $master_container (Spark $SPARK_VERSION):${NC}"
            docker logs -f "$master_container"
            ;;
        spark-worker)
            echo -e "${YELLOW}Logs for $worker_container (Spark $SPARK_VERSION):${NC}"
            docker logs -f "$worker_container"
            ;;
        kafka)
            docker logs -f kafka
            ;;
        zookeeper)
            docker logs -f zookeeper
            ;;
        *)
            echo "Usage: lakehouse logs [spark-master|spark-worker|kafka|zookeeper] [--version 4.0|4.1]"
            exit 1
            ;;
    esac
}

# Test command
cmd_test() {
    header "RUNNING TESTS"
    local master_container=$(get_spark_master_container)

    echo -e "${YELLOW}1. Testing PostgreSQL connection...${NC}"
    local pg_user="${POSTGRES_USER:-postgres}"
    local pg_host="${POSTGRES_HOST:-localhost}"
    pg_host="${pg_host/host.docker.internal/localhost}"  # Convert Docker hostname to localhost
    psql -h "$pg_host" -U "$pg_user" -d iceberg_catalog -c "SELECT 1;" 2>/dev/null && echo -e "${GREEN}OK${NC}" || echo -e "${RED}Failed - check POSTGRES_USER in .env${NC}"

    echo -e "\n${YELLOW}2. Testing SeaweedFS...${NC}"
    curl -s http://localhost:8333 > /dev/null && echo -e "${GREEN}OK${NC}" || echo -e "${RED}Failed${NC}"

    echo -e "\n${YELLOW}3. Testing Kafka...${NC}"
    docker exec kafka kafka-topics --list --bootstrap-server localhost:9092 2>/dev/null && echo -e "${GREEN}OK${NC}" || echo -e "${RED}Failed${NC}"

    echo -e "\n${YELLOW}4. Testing Spark $SPARK_VERSION ($master_container)...${NC}"
    docker exec "$master_container" /opt/spark/bin/spark-submit --version 2>&1 | grep version || echo -e "${RED}Failed${NC}"
}

# Producer command
cmd_producer() {
    header "STARTING KAFKA PRODUCER"
    poetry run python scripts/kafka-producer.py
}

# Consumer command
cmd_consumer() {
    header "STARTING SPARK CONSUMER"
    local master_container=$(get_spark_master_container)
    local kafka_package

    case $SPARK_VERSION in
        4.0) kafka_package="org.apache.spark:spark-sql-kafka-0-10_2.13:4.0.1" ;;
        4.1) kafka_package="org.apache.spark:spark-sql-kafka-0-10_2.13:4.1.0" ;;
        *) kafka_package="org.apache.spark:spark-sql-kafka-0-10_2.13:4.1.0" ;;
    esac

    echo -e "${YELLOW}Using Spark $SPARK_VERSION ($master_container)${NC}"
    docker exec "$master_container" /opt/spark/bin/spark-submit \
        --packages "$kafka_package" \
        --conf spark.jars.ivy=/opt/spark/.ivy2 \
        /scripts/test-kafka.py
}

# Testdata commands
cmd_testdata() {
    local subcmd=$1
    shift

    case $subcmd in
        generate)
            header "GENERATING TEST DATA"
            poetry run python -m scripts.testdata generate "$@"
            ;;
        stream)
            header "STREAMING TO KAFKA"
            poetry run python -m scripts.testdata stream "$@"
            ;;
        load)
            header "LOADING TO ICEBERG"
            local master_container=$(get_spark_master_container)
            if [ -f "data/load_to_iceberg.py" ]; then
                # Copy load script to scripts dir (which is mounted in container)
                cp data/load_to_iceberg.py scripts/_load_to_iceberg.py
                docker exec "$master_container" /opt/spark/bin/spark-submit \
                    /scripts/_load_to_iceberg.py
                rm -f scripts/_load_to_iceberg.py
            else
                echo -e "${RED}No load script found. Run 'lakehouse testdata generate' first.${NC}"
                exit 1
            fi
            ;;
        stats)
            header "TEST DATA STATISTICS"
            poetry run python -m scripts.testdata stats "$@"
            ;;
        clean)
            header "CLEANING TEST DATA"
            poetry run python -m scripts.testdata clean "$@"
            ;;
        *)
            echo "Usage: lakehouse testdata <command> [options]"
            echo ""
            echo "Commands:"
            echo "  generate [--days N] [--seed N]    Generate test dataset"
            echo "  stream [--speed N]                Stream events to Kafka"
            echo "  load                              Load data into Iceberg tables"
            echo "  stats                             Show dataset statistics"
            echo "  clean                             Remove generated data"
            echo ""
            echo "Examples:"
            echo "  lakehouse testdata generate --days 90"
            echo "  lakehouse testdata stream --speed 60"
            echo "  lakehouse testdata load"
            exit 1
            ;;
    esac
}

# Setup command - validates and configures everything
cmd_setup() {
    header "LAKEHOUSE SETUP"
    local has_errors=0

    # Step 1: Check prerequisites
    echo -e "\n${YELLOW}1. Checking prerequisites...${NC}"
    if ! check_prerequisites; then
        echo -e "\n${RED}Please install missing tools before continuing.${NC}"
        echo "See SETUP.md for installation instructions."
        has_errors=1
    else
        echo -e "${GREEN}✓ All required tools installed${NC}"
    fi

    # Step 2: Check .env file
    echo -e "\n${YELLOW}2. Checking configuration files...${NC}"
    if [ ! -f "$PROJECT_ROOT/.env" ]; then
        if [ -f "$PROJECT_ROOT/.env.example" ]; then
            cp "$PROJECT_ROOT/.env.example" "$PROJECT_ROOT/.env"
            echo -e "${YELLOW}!${NC} Created .env from .env.example"
            echo -e "  ${YELLOW}→ Please edit .env with your credentials${NC}"
            has_errors=1
        else
            echo -e "${RED}✗${NC} Missing .env and .env.example"
            has_errors=1
        fi
    else
        echo -e "${GREEN}✓${NC} .env exists"
        # Validate required variables
        source "$PROJECT_ROOT/.env"
        local env_ok=1
        [ -z "$POSTGRES_USER" ] && echo -e "  ${RED}✗${NC} POSTGRES_USER not set" && env_ok=0
        [ -z "$S3_ACCESS_KEY" ] && echo -e "  ${RED}✗${NC} S3_ACCESS_KEY not set" && env_ok=0
        [ "$POSTGRES_USER" = "your_username" ] && echo -e "  ${YELLOW}!${NC} POSTGRES_USER still has default value" && env_ok=0
        [ "$S3_ACCESS_KEY" = "your_access_key_here" ] && echo -e "  ${YELLOW}!${NC} S3_ACCESS_KEY still has default value" && env_ok=0
        [ $env_ok -eq 1 ] && echo -e "  ${GREEN}✓${NC} Required variables set"
    fi

    # Step 3: Check Spark config
    if [ ! -f "$PROJECT_ROOT/config/spark/spark-defaults.conf" ]; then
        if [ -f "$PROJECT_ROOT/config/spark/spark-defaults.conf.example" ]; then
            cp "$PROJECT_ROOT/config/spark/spark-defaults.conf.example" "$PROJECT_ROOT/config/spark/spark-defaults.conf"
            echo -e "${YELLOW}!${NC} Created spark-defaults.conf from example"
            echo -e "  ${YELLOW}→ Please edit with your S3/PostgreSQL credentials${NC}"
            has_errors=1
        else
            echo -e "${RED}✗${NC} Missing spark-defaults.conf"
            has_errors=1
        fi
    else
        echo -e "${GREEN}✓${NC} spark-defaults.conf exists"
    fi

    # Step 4: Check JARs
    echo -e "\n${YELLOW}3. Checking JAR dependencies...${NC}"
    local jars_dir="$PROJECT_ROOT/jars"
    local required_jars=(
        "iceberg-spark-runtime-4.0_2.13-1.10.0.jar"
        "hadoop-aws-3.4.1.jar"
        "aws-java-sdk-bundle-1.12.780.jar"
        "bundle-2.24.6.jar"
        "postgresql-42.7.4.jar"
    )
    local missing_jars=0
    for jar in "${required_jars[@]}"; do
        if [ ! -f "$jars_dir/$jar" ]; then
            echo -e "  ${RED}✗${NC} Missing $jar"
            missing_jars=1
        fi
    done

    if [ $missing_jars -eq 1 ]; then
        echo -e "\n${YELLOW}Downloading missing JARs...${NC}"
        if [ -f "$PROJECT_ROOT/scripts/download-jars.sh" ]; then
            bash "$PROJECT_ROOT/scripts/download-jars.sh"
        else
            echo -e "${RED}✗${NC} download-jars.sh not found"
            has_errors=1
        fi
    else
        echo -e "${GREEN}✓${NC} All required JARs present"
    fi

    # Step 5: Install Python dependencies
    echo -e "\n${YELLOW}4. Installing Python dependencies...${NC}"
    if check_cmd poetry; then
        poetry install --quiet && echo -e "${GREEN}✓${NC} Python dependencies installed" || {
            echo -e "${RED}✗${NC} Poetry install failed"
            has_errors=1
        }
    fi

    # Step 6: Check disk space
    echo -e "\n${YELLOW}5. Checking disk space...${NC}"
    local free_gb=$(df -BG "$PROJECT_ROOT" | tail -1 | awk '{print $4}' | tr -d 'G')
    if [ "$free_gb" -lt 10 ] 2>/dev/null; then
        echo -e "${YELLOW}!${NC} Low disk space: ${free_gb}GB free (10GB+ recommended)"
    else
        echo -e "${GREEN}✓${NC} Disk space OK (${free_gb}GB free)"
    fi

    # Step 7: Check for port conflicts
    echo -e "\n${YELLOW}6. Checking for port conflicts...${NC}"
    local ports_ok=1
    for port in 5432 8333 9092 7077 7078 8080 8082; do
        if nc -z localhost $port 2>/dev/null; then
            case $port in
                5432) echo -e "  ${GREEN}✓${NC} Port $port in use (PostgreSQL expected)" ;;
                8333) echo -e "  ${GREEN}✓${NC} Port $port in use (SeaweedFS expected)" ;;
                *) echo -e "  ${YELLOW}!${NC} Port $port already in use" ;;
            esac
        fi
    done

    # Summary
    echo -e "\n${BLUE}================================${NC}"
    if [ $has_errors -eq 0 ]; then
        echo -e "${GREEN}Setup complete!${NC}"
        echo -e "\nNext steps:"
        echo "  1. Start services:  ./lakehouse start all"
        echo "  2. Run tests:       ./lakehouse test"
    else
        echo -e "${YELLOW}Setup incomplete - please address the issues above${NC}"
        echo -e "\nSee SETUP.md for detailed instructions."
        return 1
    fi
}

# Help
cmd_help() {
    echo "Lakehouse Management CLI"
    echo ""
    echo "Usage: lakehouse <command> [options] [--version 4.0|4.1]"
    echo ""
    echo "Commands:"
    echo "  setup               Validate environment and install dependencies"
    echo "  status              Show all services status"
    echo "  start [service]     Start service (spark|kafka|all)"
    echo "  stop [service]      Stop service (spark|kafka|all)"
    echo "  restart [service]   Restart service"
    echo "  logs [service]      Tail logs (spark-master|spark-worker|kafka|zookeeper)"
    echo "  test                Run connectivity tests"
    echo "  producer            Start Kafka event producer"
    echo "  consumer            Start Spark streaming consumer"
    echo "  testdata <cmd>      Test data generation (generate|stream|load|stats|clean)"
    echo "  help                Show this help"
    echo ""
    echo "Options:"
    echo "  --version 4.0|4.1   Select Spark version (default: 4.1)"
    echo ""
    echo "Spark Versions:"
    echo "  4.0 - Port 7077, UI 8080 (docker-compose.yml)"
    echo "  4.1 - Port 7078, UI 8082 (docker-compose-spark41.yml)"
    echo ""
    echo "Test Data Commands:"
    echo "  testdata generate   Generate 90-day dataset (~75K orders)"
    echo "  testdata stream     Stream events to Kafka with speed multiplier"
    echo "  testdata load       Load generated data into Iceberg tables"
    echo "  testdata stats      Show dataset statistics"
    echo "  testdata clean      Remove generated data"
    echo ""
    echo "Examples:"
    echo "  lakehouse status"
    echo "  lakehouse start all"
    echo "  lakehouse start spark --version 4.0"
    echo "  lakehouse testdata generate --days 30"
    echo "  lakehouse testdata stream --speed 100"
}

# Main
# Parse --version flag from all args
parse_version "$@"

case ${1:-help} in
    setup)
        cmd_setup
        ;;
    status)
        cmd_status
        ;;
    start)
        cmd_start ${2:-all}
        ;;
    stop)
        cmd_stop ${2:-all}
        ;;
    restart)
        cmd_stop ${2:-all}
        sleep 2
        cmd_start ${2:-all}
        ;;
    logs)
        cmd_logs $2
        ;;
    test)
        cmd_test
        ;;
    producer)
        cmd_producer
        ;;
    consumer)
        cmd_consumer
        ;;
    testdata)
        cmd_testdata "${@:2}"
        ;;
    help|*)
        cmd_help
        ;;
esac
