# =============================================================================
# Spark Configuration for Production LanceDB Workloads
# =============================================================================
# This configuration is optimized for production Lance + Iceberg workloads.
# Copy to config/spark/spark-defaults.conf and update credentials.
#
# Key optimizations:
# - Tuned memory and executor settings for vector operations
# - Optimized shuffle and compression for embeddings
# - Configured for concurrent access patterns
# =============================================================================

# -----------------------------------------------------------------------------
# Iceberg Catalog Configuration (Primary Structured Data)
# -----------------------------------------------------------------------------
spark.sql.extensions                           org.apache.iceberg.spark.extensions.IcebergSparkSessionExtensions
spark.sql.catalog.iceberg                      org.apache.iceberg.spark.SparkCatalog
spark.sql.catalog.iceberg.type                 jdbc
spark.sql.catalog.iceberg.uri                  jdbc:postgresql://localhost:5432/iceberg_catalog
spark.sql.catalog.iceberg.jdbc.user            iceberg
spark.sql.catalog.iceberg.jdbc.password        your-password-here
spark.sql.catalog.iceberg.warehouse            s3a://lakehouse/warehouse
spark.sql.catalog.iceberg.io-impl              org.apache.iceberg.aws.s3.S3FileIO

# Iceberg Performance Tuning
spark.sql.catalog.iceberg.cache-enabled        true
spark.sql.catalog.iceberg.cache.expiration-interval-ms  60000

# -----------------------------------------------------------------------------
# Lance Catalog Configuration (Multimodal/Vector Data)
# -----------------------------------------------------------------------------
spark.sql.catalog.lance                        com.lancedb.spark.LanceCatalog
spark.sql.catalog.lance.type                   lance
spark.sql.catalog.lance.warehouse              s3a://lakehouse/lance

# Lance-specific tuning
spark.lance.read.batch-size                    8192
spark.lance.write.batch-size                   4096
spark.lance.index.nprobes                      20
spark.lance.index.refine-factor                10

# -----------------------------------------------------------------------------
# S3/SeaweedFS Storage Configuration
# -----------------------------------------------------------------------------
spark.hadoop.fs.s3a.endpoint                   http://localhost:8333
spark.hadoop.fs.s3a.access.key                 your-access-key
spark.hadoop.fs.s3a.secret.key                 your-secret-key
spark.hadoop.fs.s3a.path.style.access          true
spark.hadoop.fs.s3a.impl                       org.apache.hadoop.fs.s3a.S3AFileSystem
spark.hadoop.fs.s3a.connection.ssl.enabled     false

# S3 Performance Tuning
spark.hadoop.fs.s3a.connection.maximum         100
spark.hadoop.fs.s3a.threads.max                64
spark.hadoop.fs.s3a.fast.upload                true
spark.hadoop.fs.s3a.fast.upload.buffer         disk
spark.hadoop.fs.s3a.multipart.size             64M
spark.hadoop.fs.s3a.block.size                 64M

# -----------------------------------------------------------------------------
# Memory Configuration for Vector Workloads
# -----------------------------------------------------------------------------
# Driver memory (increase for large embedding operations)
spark.driver.memory                            8g
spark.driver.maxResultSize                     4g
spark.driver.memoryOverhead                    1g

# Executor memory (key for vector operations)
spark.executor.memory                          16g
spark.executor.memoryOverhead                  2g
spark.executor.cores                           4

# Memory fractions optimized for vector data
spark.memory.fraction                          0.8
spark.memory.storageFraction                   0.3

# Off-heap memory for Arrow/Lance operations
spark.memory.offHeap.enabled                   true
spark.memory.offHeap.size                      4g

# -----------------------------------------------------------------------------
# Shuffle Configuration for Embeddings
# -----------------------------------------------------------------------------
# Embeddings are large - optimize shuffle
spark.shuffle.compress                         true
spark.shuffle.spill.compress                   true
spark.shuffle.file.buffer                      64k

# Reduce shuffle partitions for vector operations
spark.sql.shuffle.partitions                   32

# Enable adaptive query execution
spark.sql.adaptive.enabled                     true
spark.sql.adaptive.coalescePartitions.enabled  true
spark.sql.adaptive.advisoryPartitionSizeInBytes  256m

# -----------------------------------------------------------------------------
# Serialization for Vector Data
# -----------------------------------------------------------------------------
spark.serializer                               org.apache.spark.serializer.KryoSerializer
spark.kryoserializer.buffer                    64m
spark.kryoserializer.buffer.max                512m

# Register Lance/Arrow classes for Kryo
spark.kryo.registrationRequired                false

# Arrow optimization for Python/Pandas
spark.sql.execution.arrow.pyspark.enabled      true
spark.sql.execution.arrow.pyspark.fallback.enabled  true
spark.sql.execution.arrow.maxRecordsPerBatch   10000

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------
spark.network.timeout                          600s
spark.rpc.askTimeout                           600s
spark.rpc.lookupTimeout                        300s

# Heartbeat for long-running embedding operations
spark.executor.heartbeatInterval               30s
spark.storage.blockManagerSlaveTimeoutMs       300000

# -----------------------------------------------------------------------------
# Dynamic Allocation (optional, disable for predictable vector workloads)
# -----------------------------------------------------------------------------
spark.dynamicAllocation.enabled                false
# If enabled:
# spark.dynamicAllocation.minExecutors         2
# spark.dynamicAllocation.maxExecutors         10
# spark.dynamicAllocation.initialExecutors     4

# -----------------------------------------------------------------------------
# Speculation (disable for embedding operations - they vary in time)
# -----------------------------------------------------------------------------
spark.speculation                              false

# -----------------------------------------------------------------------------
# Event Logging for Monitoring
# -----------------------------------------------------------------------------
spark.eventLog.enabled                         true
spark.eventLog.dir                             /opt/spark-data/events
spark.eventLog.compress                        true

# History server
spark.history.fs.logDirectory                  /opt/spark-data/events
spark.history.ui.port                          18080

# -----------------------------------------------------------------------------
# UI and Metrics
# -----------------------------------------------------------------------------
spark.ui.enabled                               true
spark.ui.showConsoleProgress                   true

# Prometheus metrics
spark.metrics.namespace                        lakehouse_lance
spark.metrics.conf.*.sink.prometheusServlet.class  org.apache.spark.metrics.sink.PrometheusServlet
spark.metrics.conf.*.sink.prometheusServlet.path   /metrics/prometheus

# -----------------------------------------------------------------------------
# Security (enable for production)
# -----------------------------------------------------------------------------
# spark.authenticate                           true
# spark.authenticate.secret                    your-secret-here
# spark.network.crypto.enabled                 true
# spark.ssl.enabled                            true

# -----------------------------------------------------------------------------
# Python/PySpark Configuration
# -----------------------------------------------------------------------------
spark.pyspark.python                           python3
spark.pyspark.driver.python                    python3

# Python worker memory
spark.python.worker.memory                     1g
spark.python.worker.reuse                      true

# -----------------------------------------------------------------------------
# JAR Dependencies
# -----------------------------------------------------------------------------
# Include Lance and Iceberg JARs
spark.jars.packages                            org.apache.iceberg:iceberg-spark-runtime-4.0_2.13:1.10.0
spark.jars                                     /opt/spark/jars-extra/lance-spark-bundle-4.0_2.13-0.0.15.jar

# -----------------------------------------------------------------------------
# Default Database
# -----------------------------------------------------------------------------
spark.sql.defaultCatalog                       iceberg
spark.sql.catalog.iceberg.default-namespace    bronze
