# =============================================================================
# LanceDB Production Environment Configuration
# =============================================================================
# Copy this file to production.env and update values for your environment.
# These variables configure the Lance-enabled Spark cluster and monitoring.
# =============================================================================

# -----------------------------------------------------------------------------
# Storage Configuration
# -----------------------------------------------------------------------------
# Local filesystem path for Lance data
LANCE_PATH=/opt/lance-data

# S3-compatible storage (SeaweedFS, MinIO, AWS S3)
LANCE_S3_BUCKET=lakehouse-lance
LANCE_S3_ENDPOINT=http://seaweedfs:8333
LANCE_S3_ACCESS_KEY=your-access-key
LANCE_S3_SECRET_KEY=your-secret-key
LANCE_S3_REGION=us-east-1

# Storage backend: "local" or "s3"
LANCE_STORAGE_BACKEND=local

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------
# Use mock embeddings for testing (set to false for production)
USE_MOCK_EMBEDDINGS=false

# Text embedding model (sentence-transformers)
# Options: all-MiniLM-L6-v2 (384d, fast), all-mpnet-base-v2 (768d, accurate)
LANCE_TEXT_MODEL=all-MiniLM-L6-v2

# Image embedding model (CLIP)
LANCE_IMAGE_MODEL=openai/clip-vit-base-patch32

# Embedding batch size
LANCE_EMBEDDING_BATCH_SIZE=32

# -----------------------------------------------------------------------------
# Vector Index Configuration
# -----------------------------------------------------------------------------
# Distance metric: L2, cosine, dot
LANCE_INDEX_METRIC=L2

# Number of IVF partitions (increase for larger datasets)
LANCE_INDEX_PARTITIONS=256

# Number of PQ sub-vectors (higher = more compression, less accuracy)
LANCE_INDEX_SUB_VECTORS=16

# Minimum rows before creating index
LANCE_INDEX_MIN_ROWS=256

# nprobes for search (higher = more accurate, slower)
LANCE_SEARCH_NPROBES=20

# refine factor for search quality
LANCE_SEARCH_REFINE_FACTOR=10

# -----------------------------------------------------------------------------
# Concurrent Write Configuration
# -----------------------------------------------------------------------------
# Enable write locking for multi-process safety
LANCE_WRITE_LOCKING=true

# Lock directory for file-based locks
LANCE_LOCK_DIR=/tmp/lance_locks

# Lock timeout in seconds
LANCE_LOCK_TIMEOUT=30

# Number of write retries on conflict
LANCE_WRITE_RETRIES=3

# Retry delay in seconds
LANCE_WRITE_RETRY_DELAY=1.0

# -----------------------------------------------------------------------------
# Compaction Configuration
# -----------------------------------------------------------------------------
# Maximum rows before triggering compaction
LANCE_COMPACT_MAX_ROWS=1000000

# Maximum fragments before compaction
LANCE_COMPACT_MAX_FRAGMENTS=100

# Target rows per fragment after compaction
LANCE_COMPACT_TARGET_ROWS=100000

# -----------------------------------------------------------------------------
# Monitoring Configuration
# -----------------------------------------------------------------------------
# Enable Prometheus metrics export
LANCE_METRICS_ENABLED=true

# Metrics HTTP server port
LANCE_METRICS_PORT=9090

# Health check interval in seconds
LANCE_HEALTH_CHECK_INTERVAL=60

# Enable alerting
LANCE_ALERTING_ENABLED=true

# Alert thresholds
LANCE_ALERT_QUERY_LATENCY_MS=1000
LANCE_ALERT_WRITE_ERROR_RATE=0.05
LANCE_ALERT_DISK_USAGE_PERCENT=85

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
LANCE_LOG_LEVEL=INFO

# Log format: json or text
LANCE_LOG_FORMAT=json

# Log file path (empty for stdout only)
LANCE_LOG_FILE=/var/log/lance/lance.log

# -----------------------------------------------------------------------------
# Kafka Integration
# -----------------------------------------------------------------------------
# Kafka bootstrap servers
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Consumer group for Lance ingestion
LANCE_KAFKA_CONSUMER_GROUP=lance-ingest

# Topics to consume
LANCE_KAFKA_TOPICS=products,embeddings

# Auto offset reset: earliest, latest
LANCE_KAFKA_AUTO_OFFSET_RESET=latest

# Batch size for Kafka to Lance writes
LANCE_KAFKA_BATCH_SIZE=100

# -----------------------------------------------------------------------------
# Spark Integration
# -----------------------------------------------------------------------------
# Spark master URL
SPARK_MASTER_URL=spark://localhost:7079

# Lance catalog name in Spark
LANCE_CATALOG_NAME=lance

# Number of partitions for Spark reads
LANCE_SPARK_PARTITIONS=8

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------
# Enable automatic backups
LANCE_BACKUP_ENABLED=false

# Backup storage path
LANCE_BACKUP_PATH=/opt/lance-backups

# Backup retention days
LANCE_BACKUP_RETENTION_DAYS=7

# Backup schedule (cron expression)
LANCE_BACKUP_SCHEDULE=0 2 * * *
